{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@fixtures/core": ["../core/src"],
      "@fixtures/core/*": ["../core/src/*"],
      "@fixtures/types": ["../types/src"]
    }
  },
  "include": ["src"]
}

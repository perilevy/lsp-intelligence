{
  "routes": {
    "/api/users": { "handler": "UserController", "method": "GET" },
    "/api/users/:id": { "handler": "UserController", "method": "GET" },
    "/api/items": { "handler": "ItemController", "method": "GET" },
    "/api/items/:id/status": { "handler": "StatusController", "method": "PUT" },
    "/health": { "handler": "HealthCheck", "method": "GET" }
  },
  "middleware": {
    "auth": ["api/users", "api/items"],
    "rateLimit": ["api/users"]
  }
}
